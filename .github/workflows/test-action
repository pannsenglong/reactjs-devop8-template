# condition ( when to run this ? )
on: 
  push: 
    branches: ["master"]
# tasks ( what are the task that we automate )
env: 
  DH_IMAGE: devops11-basic-reactjs
jobs:
 build-and-push: 
  runs-on: ubuntu-latest
  environment: DH_ENV
  steps: 
    - name: Checkout 
      uses: actions/checkout@v3
    - name: Version using Git SHA
      run: |
        echo "TAG=${GITHUB_SHA::8}" >> $GITHUB_ENV
    - name: Login to Dockerhub 
      run: |
       echo "${{ secrets.PASSWORD }}" |  docker login -u ${{ secrets.USERNAME }} --password-stdin

    - name: Build Docker images 
      run: docker build -t ${{ secrets.USERNAME}}/${{env.DH_IMAGE}}:${{env.TAG}} .

    - name: Push image 
      run: docker push ${{ secrets.USERNAME}}/${{env.DH_IMAGE}}:${{env.TAG}}
    - name: Always logout 
      if: always()
      run: docker logout